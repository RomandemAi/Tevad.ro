# Tevad.ro — Environment Variables
# Copy to .env.local (web app) or .env (packages)
# Never commit actual values to git

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose to client

# ---- Anthropic Claude API ----
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- Scraper config ----
SCRAPER_DELAY_MS=500          # delay between requests (polite crawling)
SCRAPER_USER_AGENT=Tevad.ro Data Pipeline (contact: open@tevad.ro)

# ---- App ----
NEXT_PUBLIC_APP_URL=https://tevad.ro
NODE_ENV=development
