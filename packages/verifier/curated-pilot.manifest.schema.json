{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tevad curated verifier pilot manifest",
  "type": "object",
  "required": ["version", "entries"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "description": { "type": "string" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "politician_slug",
          "record_slug",
          "type",
          "text",
          "date_made",
          "impact_level",
          "sources"
        ],
        "properties": {
          "politician_slug": { "type": "string", "minLength": 1 },
          "record_slug": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["promise", "statement", "vote"] },
          "text": { "type": "string", "minLength": 1 },
          "context": { "type": "string" },
          "topic": { "type": "string" },
          "date_made": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
          "impact_level": { "type": "string", "enum": ["high", "medium", "low"] },
          "sources": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["tier", "outlet", "url"],
              "properties": {
                "tier": { "type": "integer", "minimum": 0, "maximum": 2 },
                "outlet": { "type": "string" },
                "url": { "type": "string", "format": "uri" },
                "title": { "type": "string" },
                "excerpt": { "type": "string" },
                "published_at": { "type": "string" },
                "archived_url": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
