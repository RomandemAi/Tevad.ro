# Supabase (Next.js uses NEXT_PUBLIC_*; scraper / verifier / rss-monitor accept either URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# xAI (Grok) — required 3rd verifier model in the ensemble (v1.3.0); never expose client-side.
XAI_API_KEY=

# App (production: e.g. https://tevad.org — must match your Netlify primary domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# First-visit modal: beta launch date (YYYY-MM-DD) shown as calendar date + „acum N zile”
NEXT_PUBLIC_BETA_LAUNCH_DATE=2026-04-14

# RSS → verification_queue: min Haiku confidence to enqueue (45–90). Default 58 = easy queue; stricter final verdict is only from /api/cron/verify (ensemble, unchanged).
# RSS_QUEUE_MIN_CONFIDENCE=58

# Cron (Vercel / Netlify / manual): Authorization: Bearer <secret> on /api/cron/*
# External schedulers (cron-job.org): set request timeout ≥ 60s to match Netlify/Next cron routes.
# Source health: default `limit=12` per run; use `?limit=30` only if your scheduler allows a long window.
# Netlify: set CRON_SECRET in the UI; scheduled function `cron-rss-watch` calls /api/cron/rss-watch (URL is set by Netlify).
# GitHub Actions (.github/workflows/*): add repository secrets — SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY,
# ANTHROPIC_API_KEY, XAI_API_KEY (Grok), and NEXT_PUBLIC_SUPABASE_ANON_KEY where applicable. Cron verify: GET /api/cron/verify?limit=3
# Manual workflow `.github/workflows/grok-smoke.yml` smoke-tests xAI only.
CRON_SECRET=
# Local: npm run cron:rss hits this base URL (default http://localhost:3001). Not NEXT_PUBLIC_APP_URL.
# CRON_TRIGGER_URL=http://localhost:3001
